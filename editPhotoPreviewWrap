  <script>
document.addEventListener('DOMContentLoaded', function () {
  const breakpoint = window.matchMedia('(max-width: 1024px)');

  const mobileProfileNav =
    document.getElementById('mobileProfileNav');

  const profileBox =
    document.getElementById('profileBox');

  const profileBody =
    profileBox?.querySelector('.profile-body');

  const profileStats =
    profileBox?.querySelector('.profile-stats');

  const profileStat =
    profileBox?.querySelector('.profile-stat');

  const profileActionRow =
    profileBox?.querySelector('.profile-action-row');

const profileCartBtn =
  document.getElementById('profileCartBtn');

const elements = [
  document.getElementById('profileHours'),
  document.getElementById('profileLoginBtn'),
  document.getElementById('profileName'),
  document.getElementById('profilePhoto')
].filter(Boolean);

  /*
   * เก็บตำแหน่งเดิมของแต่ละ Element
   * เพื่อให้ย้ายกลับได้เมื่อเปิดบนคอมพิวเตอร์
   */
  const originalPositions = new Map();

  elements.forEach(function (element) {
    originalPositions.set(element, {
      parent: element.parentNode,
      nextSibling: element.nextSibling
    });
  });

  function moveToMobileHeader() {
    if (!mobileProfileNav) return;

elements.forEach(function (element) {
    mobileProfileNav.appendChild(element);
});

if (profileCartBtn) {
    mobileProfileNav.prepend(profileCartBtn);
}

    if (profileBox) {
      profileBox.hidden = true;
      profileBox.setAttribute('aria-hidden', 'true');
    }
  }

  function restoreToProfileBox() {
    elements.forEach(function (element) {
      if (profileCartBtn) {
    profileCartBtn.remove();
}
      const position = originalPositions.get(element);

      if (!position?.parent) return;

      if (
        position.nextSibling &&
        position.nextSibling.parentNode === position.parent
      ) {
        position.parent.insertBefore(
          element,
          position.nextSibling
        );
      } else {
        position.parent.appendChild(element);
      }
    });

    if (profileBox) {
const navWrap =
    document.querySelector(".nav-wrap");

if (profileCartBtn) {
    navWrap.appendChild(profileCartBtn);
}

profileBox.hidden = false;
      profileBox.removeAttribute('aria-hidden');
    }
  }

  function updateProfileLocation(event) {
    if (event.matches) {
      moveToMobileHeader();
    } else {
      restoreToProfileBox();
    }
  }

  updateProfileLocation(breakpoint);

  if (typeof breakpoint.addEventListener === 'function') {
    breakpoint.addEventListener(
      'change',
      updateProfileLocation
    );
  } else {
    breakpoint.addListener(updateProfileLocation);
  }
});
</script>
